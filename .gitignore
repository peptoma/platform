# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# Replit platform files (not needed for development outside Replit)
.replit
.replitignore
.cache/
.local/
.agents/
.config/
.pythonlibs/
attached_assets/
screenshots/
replit.md

# Replit artifact config (platform routing — not needed outside Replit)
.replit-artifact/

# Environment variables (never commit secrets)
.env
.env.local
.env.*.local
